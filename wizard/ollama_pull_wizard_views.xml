<?xml version="1.0"?>
<odoo>

    <record id="ollama_pull_wizard_form" model="ir.ui.view">
        <field name="name">ollama.pull.wizard.form</field>
        <field name="model">ollama.pull.wizard</field>
        <field name="arch" type="xml">
            <form string="Pull Ollama Model">
                <group>
                    <field name="model_to_pull" widget="selection"/>
                </group>
                <div class="text-muted mb-3" style="font-size: 12px;">
                    Browse all models at <a href="https://ollama.com/library" target="_blank">ollama.com/library</a>
                </div>
                <footer>
                    <button name="action_pull" type="object" string="⬇ Pull Model" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ollama_pull_wizard" model="ir.actions.act_window">
        <field name="name">Pull Ollama Model</field>
        <field name="res_model">ollama.pull.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
