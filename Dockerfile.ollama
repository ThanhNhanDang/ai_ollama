# Custom Ollama image with FastAPI sidecar for system-info endpoint
FROM ollama/ollama:latest

# Install Python + FastAPI deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    && pip3 install --break-system-packages fastapi uvicorn \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy sidecar and entrypoint
COPY ollama_sidecar.py /app/ollama_sidecar.py
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Ollama default port + sidecar port
EXPOSE 11434 11435

ENTRYPOINT ["/entrypoint.sh"]