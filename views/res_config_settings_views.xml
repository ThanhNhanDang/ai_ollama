<?xml version="1.0"?>
<odoo>

    <record id="res_config_settings_view_form_ollama" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ai.ollama</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="ai_app.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='ai_providers']" position="inside">
                <setting id="ollama_provider" string="Ollama - Local LLM" help="Connect to a local Ollama server for private AI processing" groups="base.group_system">
                    <field name="ollama_enabled" />
                    <div class="text-muted">
                        Run AI models locally — no cloud API keys needed.
                        <a href="https://ollama.com" target="_blank">Learn more</a>
                    </div>
                    <group>
                        <div class="flex-grow-1 mt-2">
                            <label for="ollama_base_url" string="Server URL"/>
                            <field name="ollama_base_url" placeholder="http://ollama:11434" nolabel="1" class="w-100"/>
                        </div>
                    </group>
                    <group invisible="not ollama_enabled">
                        <div class="flex-grow-1 mt-3">
                            <button name="action_ollama_open_dashboard"
                                    type="object"
                                    string="Open Ollama Dashboard"
                                    class="btn-primary"
                                    icon="fa-dashboard"/>
                        </div>
                    </group>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
